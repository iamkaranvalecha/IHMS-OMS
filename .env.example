# IHMS-OMS — copy to .env before deploy

# Upstream URLs (KB-IHMS docker :5000, EC-OPS on host :8002)
IHMS_BASE_URL=http://host.docker.internal:5000
ECOPS_BASE_URL=http://host.docker.internal:8002

# Required — run: bash scripts/ecops-token.sh
ECOPS_BEARER_TOKEN=

# Host ports (5180 avoids KB-IHMS frontend on 5173)
ORCHESTRATOR_PORT=8000
UI_PORT=5180
