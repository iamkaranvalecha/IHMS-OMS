# IHMS-OMS Docker environment — copy to .env and adjust.
# Used by scripts/upstream-stack.sh (real upstreams) and compose overrides.

# ── Upstream URLs (external mode: host ports from KB-IHMS / EC-OPS compose) ──
IHMS_BASE_URL=http://host.docker.internal:5000
ECOPS_BASE_URL=http://host.docker.internal:8002

# Required for confirm/reconcile — obtain via: bash scripts/ecops-token.sh
ECOPS_BEARER_TOKEN=

# EC-OPS login for scripts/ecops-token.sh (optional; prompted if unset)
# ECOPS_USERNAME=admin
# ECOPS_PASSWORD=

# ── Host port mappings (avoid 5173 — KB-IHMS frontend uses it) ───────────────
ORCHESTRATOR_PORT=8000
UI_PORT=5180
IHMS_PORT=5000
ECOPS_PORT=8002

# ── Sibling repo paths (bundle mode: bash scripts/upstream-stack.sh up --bundle)
# KB_IHMS_PATH=../KB-IHMS
# ECOPS_PATH=../EC-OPS

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
# OBS_STACK=1
# PROMETHEUS_PORT=9090

# ── Timeouts ──────────────────────────────────────────────────────────────────
ECOPS_READ_TIMEOUT=10
IHMS_READ_TIMEOUT=5
