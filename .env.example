# Real upstream overrides — copy to .env before running orchestrator + UI only.
#
# KB-IHMS docker exposes the API on host :5000. EC-OPS runs on host :8002.
IHMS_BASE_URL=http://host.docker.internal:5000
ECOPS_BASE_URL=http://host.docker.internal:8002

# Required for real EC-OPS — run: bash scripts/ecops-token.sh
ECOPS_BEARER_TOKEN=

# 5180 avoids clashing with KB-IHMS frontend on host :5173.
ORCHESTRATOR_PORT=8000
UI_PORT=5180
