# Optional overrides — copy to .env
#
# IMPORTANT: URLs depend on where the orchestrator runs.
#   localhost inside a Docker container is the container itself, not your host.
#
# Mock stack (orchestrator + mock IHMS + mock EC-OPS in Docker):
#   bash scripts/mock-stack.sh
#   IHMS_BASE_URL=http://ihms:8080
#   ECOPS_BASE_URL=http://ecops:8002
#
# Real upstreams, orchestrator in Docker (KB-IHMS :5000, EC-OPS :8002 on host):
#   bash scripts/real-upstream.sh
#   IHMS_BASE_URL=http://host.docker.internal:5000
#   ECOPS_BASE_URL=http://host.docker.internal:8002
#
# Real upstreams, orchestrator on host (uv run, not Docker):
#   IHMS_BASE_URL=http://localhost:5000
#   ECOPS_BASE_URL=http://localhost:8002

# Default stack host ports (avoid KB-IHMS :5173 and EC-OPS :8002):
#   UI 5180 | mock EC-OPS 8012 | orchestrator 8000 | mock IHMS 8080
ORCHESTRATOR_PORT=8000
UI_PORT=5180

CATALOG_SOURCE=ihms
CATALOG_FALLBACK_TO_JSON=true
ECOPS_MAPPING_PATH=/app/catalog/ecops-mapping.json

# Real upstream mode (orchestrator in Docker — use host.docker.internal, not localhost):
IHMS_BASE_URL=http://host.docker.internal:5000
ECOPS_BASE_URL=http://host.docker.internal:8002
ECOPS_BEARER_TOKEN=
